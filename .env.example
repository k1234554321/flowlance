PORT=3000
SESSION_SECRET=replace_with_strong_secret

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=aggregator_user
DB_PASSWORD=strong_password
DB_NAME=aggregator_db

DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
DEFAULT_ADMIN_PASSWORD=admin12345

# Без MySQL: вход с этим email получит роль admin (остальные — user).

PROXY_API_URL=https://your-proxy-api/v1/chat/completions
PROXY_API_KEY=replace_with_proxy_api_key
PROXY_MODEL=gpt-4o-mini

# Если VPS в регионе, где официальный OpenAI недоступен — запросы идут с СЕРВЕРА.
# Нужен прокси/API вне блокировки или другой провайдер модели (см. PROXY_* выше).

# OpenAI (если используешь официальный API вместо прокси)
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini
